---
import type { Lang } from "../data/landing";
import { landing } from "../data/landing";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = landing[lang];
const otherHref = lang === "en" ? "/es/" : "/";
---

<header class="landing-header">
  <a href={lang === "en" ? "/" : "/es/"} class="landing-logo" aria-label="Almena Network">
    <img src="/logo.svg" alt="" width="36" height="36" />
    <span>Almena Network</span>
  </a>
  <a href={otherHref} class="landing-lang">{t.langSwitch}</a>
</header>

<main class="landing-main">
  <section class="landing-hero">
    <h1 class="landing-hero__title">{t.hero.title}</h1>
    <p class="landing-hero__subtitle">{t.hero.subtitle}</p>
    <div class="landing-hero__actions">
      <a href="https://docs.almena.network" class="landing-btn landing-btn--primary" target="_blank" rel="noopener">{t.community.docs}</a>
      <a href="https://github.com/almena-network" class="landing-btn landing-btn--outline" target="_blank" rel="noopener">{t.community.github}</a>
    </div>
  </section>

  <section class="landing-features">
    <div class="landing-features-row">
      <article class="landing-feature">
        <h3 class="landing-feature__title">{t.features.identity.title}</h3>
        <p class="landing-feature__text">{t.features.identity.text}</p>
      </article>
      <article class="landing-feature">
        <h3 class="landing-feature__title">{t.features.p2p.title}</h3>
        <p class="landing-feature__text">{t.features.p2p.text}</p>
      </article>
      <article class="landing-feature">
        <h3 class="landing-feature__title">{t.features.standards.title}</h3>
        <p class="landing-feature__text">{t.features.standards.text}</p>
      </article>
    </div>
  </section>

  <section class="landing-modules">
    <h2 class="landing-section-title">{t.modules.title}</h2>
    <p class="landing-section-subtitle">{t.modules.subtitle}</p>
    <div class="landing-modules-grid">
      <article class="landing-module landing-glass">
        <div class="landing-module__icon" data-module="daemon"></div>
        <h3 class="landing-module__title">{t.modules.daemon.title}</h3>
        <p class="landing-module__text">{t.modules.daemon.text}</p>
        <code class="landing-module__tech">{t.modules.daemon.tech}</code>
      </article>
      <article class="landing-module landing-glass">
        <div class="landing-module__icon" data-module="wallet"></div>
        <h3 class="landing-module__title">{t.modules.wallet.title}</h3>
        <p class="landing-module__text">{t.modules.wallet.text}</p>
        <code class="landing-module__tech">{t.modules.wallet.tech}</code>
      </article>
      <article class="landing-module landing-glass">
        <div class="landing-module__icon" data-module="desktop"></div>
        <h3 class="landing-module__title">{t.modules.desktop.title}</h3>
        <p class="landing-module__text">{t.modules.desktop.text}</p>
        <code class="landing-module__tech">{t.modules.desktop.tech}</code>
      </article>
      <article class="landing-module landing-glass">
        <div class="landing-module__icon" data-module="cli"></div>
        <h3 class="landing-module__title">{t.modules.cli.title}</h3>
        <p class="landing-module__text">{t.modules.cli.text}</p>
        <code class="landing-module__tech">{t.modules.cli.tech}</code>
      </article>
    </div>
  </section>

  <section class="landing-community landing-glass">
    <h2 class="landing-section-title">{t.community.title}</h2>
    <p class="landing-community__text">{t.community.text}</p>
    <div class="landing-community__actions">
      <a href="https://github.com/almena-network" class="landing-btn landing-btn--primary" target="_blank" rel="noopener">{t.community.github}</a>
    </div>
  </section>
</main>

<footer class="landing-footer">
  <p>Almena Network {lang === "en" ? "is a community project" : "es un proyecto comunitario"} · {new Date().getFullYear()}</p>
</footer>

<style>
  /* Header */
  .landing-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    padding-top: max(12px, env(safe-area-inset-top));
  }

  .landing-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.15rem;
  }

  .landing-logo img {
    width: 32px;
    height: 32px;
  }

  .landing-logo:hover {
    color: var(--color-primary);
  }

  .landing-lang {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    transition: color var(--transition), background var(--transition);
  }

  .landing-lang:hover {
    color: var(--color-primary);
    background: var(--color-glass-bg);
  }

  /* Main — full width */
  .landing-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 24px 48px;
  }

  /* Hero */
  .landing-hero {
    text-align: center;
    margin-bottom: 40px;
  }

  .landing-hero__title {
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    font-weight: 700;
    margin: 0 0 12px;
    line-height: 1.15;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-text-muted) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .landing-hero__subtitle {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--color-text-muted);
    margin: 0 auto 20px;
    line-height: 1.5;
    max-width: 64ch;
  }

  .landing-hero__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Features row — 3 inline, no cards */
  .landing-features {
    margin-bottom: 40px;
  }

  .landing-features-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .landing-feature {
    text-align: center;
    padding: 0 8px;
  }

  .landing-feature__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 6px;
    color: var(--color-primary);
  }

  .landing-feature__text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Section titles */
  .landing-section-title {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0 0 6px;
    color: var(--color-primary);
    text-align: center;
  }

  .landing-section-subtitle {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 auto 20px;
    text-align: center;
    max-width: 48ch;
  }

  /* Modules grid — 4 columns */
  .landing-modules {
    margin-bottom: 40px;
  }

  .landing-modules-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .landing-glass {
    background: var(--color-glass-bg);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    border: 1px solid var(--color-glass-border);
  }

  .landing-module {
    padding: 20px;
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition), transform var(--transition);
  }

  .landing-module:hover {
    border-color: rgba(251, 146, 60, 0.3);
    transform: translateY(-2px);
  }

  .landing-module__icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    margin-bottom: 10px;
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.2), rgba(139, 92, 246, 0.15));
    border: 1px solid rgba(251, 146, 60, 0.2);
    position: relative;
  }

  .landing-module__icon::after {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    line-height: 1;
  }

  .landing-module__icon[data-module="daemon"]::after { content: "\1F310"; }
  .landing-module__icon[data-module="wallet"]::after { content: "\1F4B3"; }
  .landing-module__icon[data-module="desktop"]::after { content: "\1F5A5\FE0F"; }
  .landing-module__icon[data-module="cli"]::after { content: "\2328\FE0F"; }

  .landing-module__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 6px;
    color: var(--color-text);
  }

  .landing-module__text {
    flex: 1;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0 0 10px;
    line-height: 1.45;
  }

  .landing-module__tech {
    font-size: 0.6875rem;
    color: #78716c;
    background: rgba(255, 255, 255, 0.04);
    padding: 3px 8px;
    border-radius: 4px;
    align-self: flex-start;
  }

  /* Community banner */
  .landing-community {
    padding: 28px 32px;
    border-radius: var(--radius);
    text-align: center;
  }

  .landing-community__text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 8px auto 20px;
    max-width: 64ch;
    line-height: 1.5;
  }

  .landing-community__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  /* Buttons */
  .landing-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 24px;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: inherit;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--transition), color var(--transition), transform var(--transition);
  }

  .landing-btn--primary {
    background: var(--color-primary);
    color: #0c0a09;
    border: none;
  }

  .landing-btn--primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .landing-btn--outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .landing-btn--outline:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.35);
    transform: translateY(-1px);
  }

  /* Footer */
  .landing-footer {
    text-align: center;
    padding: 20px 24px;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
  }

  .landing-footer p {
    margin: 0;
  }

  /* Responsive */
  @media screen and (max-width: 996px) {
    .landing-modules-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 640px) {
    .landing-main {
      padding: 16px 16px 40px;
    }

    .landing-hero {
      margin-bottom: 32px;
    }

    .landing-features-row {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .landing-modules-grid {
      grid-template-columns: 1fr;
    }

    .landing-community {
      padding: 24px 20px;
    }
  }
</style>
