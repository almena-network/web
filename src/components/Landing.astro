---
import type { Lang } from "../data/landing";
import { landing } from "../data/landing";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = landing[lang];
const otherHref = lang === "en" ? "/es/" : "/";
---

<header class="landing-header">
  <a href={lang === "en" ? "/" : "/es/"} class="landing-logo" aria-label="Almena Network">
    <img src="/logo.svg" alt="Almena Network" width="48" height="48" />
    <span>Almena Network</span>
  </a>
  <a href={otherHref} class="landing-lang">{t.langSwitch}</a>
</header>

<main class="landing-main">
  <section class="landing-hero">
    <h1 class="landing-hero__title">{t.hero.title}</h1>
    <p class="landing-hero__subtitle">{t.hero.subtitle}</p>
  </section>

  <section class="landing-purpose landing-glass">
    <h2 class="landing-section-title">{t.purpose.title}</h2>
    <p class="landing-text">{t.purpose.p1}</p>
    <p class="landing-text">{t.purpose.p2}</p>
  </section>

  <section class="landing-features">
    <h2 class="landing-section-title">{t.features.title}</h2>
    <div class="landing-features-grid">
      <article class="landing-card landing-glass">
        <h3 class="landing-card__title">{t.features.did.title}</h3>
        <p class="landing-card__text">{t.features.did.text}</p>
      </article>
      <article class="landing-card landing-glass">
        <h3 class="landing-card__title">{t.features.vc.title}</h3>
        <p class="landing-card__text">{t.features.vc.text}</p>
      </article>
      <article class="landing-card landing-glass">
        <h3 class="landing-card__title">{t.features.wallet.title}</h3>
        <p class="landing-card__text">{t.features.wallet.text}</p>
      </article>
      <article class="landing-card landing-glass">
        <h3 class="landing-card__title">{t.features.open.title}</h3>
        <p class="landing-card__text">{t.features.open.text}</p>
      </article>
    </div>
  </section>

  <section class="landing-cta landing-glass">
    <h2 class="landing-section-title">{t.cta.title}</h2>
    <div class="landing-cta-buttons">
      <a href="https://docs.almena.network" class="landing-btn landing-btn--primary" target="_blank" rel="noopener">{t.cta.docs}</a>
      <a href="https://github.com/almena-network" class="landing-btn landing-btn--secondary" target="_blank" rel="noopener">{t.cta.github}</a>
    </div>
  </section>
</main>

<footer class="landing-footer">
  <p>© Almena Network — {lang === "en" ? "Open source" : "Código abierto"}</p>
</footer>

<style>
  .landing-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    padding-top: max(16px, env(safe-area-inset-top));
  }

  .landing-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.25rem;
  }

  .landing-logo img {
    width: 40px;
    height: 40px;
  }

  .landing-logo:hover {
    color: var(--color-primary);
  }

  .landing-lang {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9375rem;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    transition: color var(--transition), background var(--transition);
  }

  .landing-lang:hover {
    color: var(--color-primary);
    background: var(--color-glass-bg);
  }

  .landing-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .landing-hero {
    text-align: center;
    margin-bottom: 64px;
  }

  .landing-hero__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin: 0 0 16px;
    line-height: 1.2;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-text-muted) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .landing-hero__subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
    max-width: 540px;
    margin-inline: auto;
  }

  .landing-purpose {
    padding: 32px;
    border-radius: var(--radius);
    margin-bottom: 48px;
  }

  .landing-glass {
    background: var(--color-glass-bg);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    border: 1px solid var(--color-glass-border);
  }

  .landing-section-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 16px;
    color: var(--color-primary);
  }

  .landing-text {
    margin: 0 0 12px;
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .landing-text:last-child {
    margin-bottom: 0;
  }

  .landing-features {
    margin-bottom: 48px;
  }

  .landing-features .landing-section-title {
    margin-bottom: 24px;
  }

  .landing-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .landing-card {
    padding: 24px;
    border-radius: var(--radius);
  }

  .landing-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--color-text);
  }

  .landing-card__text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .landing-cta {
    padding: 32px;
    border-radius: var(--radius);
    text-align: center;
  }

  .landing-cta .landing-section-title {
    margin-bottom: 24px;
  }

  .landing-cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }

  .landing-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-size: 1rem;
    font-weight: 600;
    font-family: inherit;
    border-radius: var(--radius);
    text-decoration: none;
    transition: background var(--transition), color var(--transition);
  }

  .landing-btn--primary {
    background: var(--color-primary);
    color: #0c0a09;
    border: none;
  }

  .landing-btn--primary:hover {
    background: var(--color-primary-hover);
  }

  .landing-btn--secondary {
    background: var(--color-glass-bg);
    color: var(--color-text);
    border: 1px solid var(--color-glass-border);
  }

  .landing-btn--secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .landing-footer {
    text-align: center;
    padding: 24px;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .landing-footer p {
    margin: 0;
  }
</style>
