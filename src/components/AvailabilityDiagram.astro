---
import type { Lang } from "../data/landing";
import { landing } from "../data/landing";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const a = landing[lang].availability;
---

<section class="landing-availability" aria-label={a.title}>
  <div class="landing-availability-grid">
    <!-- Centralized panel -->
    <figure class="landing-availability__panel landing-availability__panel--down">
      <figcaption class="landing-availability__caption">
        <span class="landing-availability__label">{a.centralizedTitle}</span>
        <span class="landing-availability__status landing-availability__status--down">{a.centralizedStatus}</span>
      </figcaption>
      <svg
        class="landing-availability__svg"
        viewBox="0 0 360 220"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label={`${a.centralizedTitle}: ${a.centralizedStatus}`}
      >
        <style>
          .av-user { fill: rgba(255, 255, 255, 0.05); stroke: rgba(255, 255, 255, 0.18); stroke-width: 1; }
          .av-user-lbl { font-family: Inter, system-ui, -apple-system, sans-serif; font-size: 9px; font-weight: 600; fill: #fafafa; }
          .av-server-down { fill: rgba(239, 68, 68, 0.1); stroke: #ef4444; stroke-width: 1.5; }
          .av-server-lbl { font-family: Inter, system-ui, -apple-system, sans-serif; font-size: 11px; font-weight: 700; fill: #fafafa; }
          .av-server-sub { font-family: Inter, system-ui, -apple-system, sans-serif; font-size: 9px; fill: #a3a3a3; }
          .av-line-dead { stroke: #ef4444; stroke-width: 1.5; fill: none; stroke-dasharray: 4 4; opacity: 0.6; }
          .av-x { stroke: #ef4444; stroke-width: 3; stroke-linecap: round; }
        </style>

        <!-- Users -->
        <g>
          <circle class="av-user" cx="40" cy="60" r="14" />
          <text class="av-user-lbl" x="40" y="63" text-anchor="middle">1</text>
          <circle class="av-user" cx="40" cy="110" r="14" />
          <text class="av-user-lbl" x="40" y="113" text-anchor="middle">2</text>
          <circle class="av-user" cx="40" cy="160" r="14" />
          <text class="av-user-lbl" x="40" y="163" text-anchor="middle">3</text>
        </g>

        <!-- Dead connections -->
        <line class="av-line-dead" x1="54" y1="60" x2="214" y2="110" />
        <line class="av-line-dead" x1="54" y1="110" x2="214" y2="110" />
        <line class="av-line-dead" x1="54" y1="160" x2="214" y2="110" />

        <!-- Central server (down) -->
        <rect class="av-server-down" x="214" y="70" width="110" height="80" rx="10" />
        <text class="av-server-lbl" x="269" y="108" text-anchor="middle">{a.centralizedServer}</text>
        <text class="av-server-sub" x="269" y="126" text-anchor="middle">{a.down}</text>

        <!-- X over server -->
        <line class="av-x" x1="228" y1="84" x2="310" y2="138" />
        <line class="av-x" x1="310" y1="84" x2="228" y2="138" />
      </svg>
    </figure>

    <!-- Decentralized panel -->
    <figure class="landing-availability__panel landing-availability__panel--up">
      <figcaption class="landing-availability__caption">
        <span class="landing-availability__label">{a.decentralizedTitle}</span>
        <span class="landing-availability__status landing-availability__status--up">{a.decentralizedStatus}</span>
      </figcaption>
      <svg
        class="landing-availability__svg"
        viewBox="0 0 360 220"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label={`${a.decentralizedTitle}: ${a.decentralizedStatus}`}
      >
        <style>
          .av-user { fill: rgba(255, 255, 255, 0.05); stroke: rgba(255, 255, 255, 0.18); stroke-width: 1; }
          .av-user-lbl { font-family: Inter, system-ui, -apple-system, sans-serif; font-size: 9px; font-weight: 600; fill: #fafafa; }
          .av-node-up { fill: rgba(34, 197, 94, 0.12); stroke: #22c55e; stroke-width: 1.5; }
          .av-node-down { fill: rgba(239, 68, 68, 0.1); stroke: #ef4444; stroke-width: 1.5; }
          .av-node-lbl { font-family: Inter, system-ui, -apple-system, sans-serif; font-size: 10px; font-weight: 700; fill: #fafafa; }
          .av-mesh { stroke: rgba(34, 197, 94, 0.45); stroke-width: 1; fill: none; }
          .av-line-live { stroke: #22c55e; stroke-width: 1.3; fill: none; stroke-dasharray: 5 3; }
          .av-line-dead { stroke: #ef4444; stroke-width: 1.3; fill: none; stroke-dasharray: 3 4; opacity: 0.55; }
          .av-x { stroke: #ef4444; stroke-width: 2; stroke-linecap: round; }
        </style>

        <!-- Users -->
        <g>
          <circle class="av-user" cx="40" cy="60" r="14" />
          <text class="av-user-lbl" x="40" y="63" text-anchor="middle">1</text>
          <circle class="av-user" cx="40" cy="110" r="14" />
          <text class="av-user-lbl" x="40" y="113" text-anchor="middle">2</text>
          <circle class="av-user" cx="40" cy="160" r="14" />
          <text class="av-user-lbl" x="40" y="163" text-anchor="middle">3</text>
        </g>

        <!-- Node mesh (live green) -->
        <g aria-hidden="true">
          <line class="av-mesh" x1="170" y1="55" x2="280" y2="55" />
          <line class="av-mesh" x1="170" y1="55" x2="220" y2="110" />
          <line class="av-mesh" x1="280" y1="55" x2="220" y2="110" />
          <line class="av-mesh" x1="220" y1="110" x2="170" y2="165" />
          <line class="av-mesh" x1="220" y1="110" x2="280" y2="165" />
          <line class="av-mesh" x1="170" y1="165" x2="280" y2="165" />
        </g>

        <!-- User → node connections (live to available nodes, dead to the down one) -->
        <line class="av-line-live" x1="54" y1="60" x2="156" y2="55" />
        <line class="av-line-dead" x1="54" y1="110" x2="206" y2="110" />
        <line class="av-line-live" x1="54" y1="110" x2="266" y2="55" />
        <line class="av-line-live" x1="54" y1="160" x2="156" y2="165" />
        <line class="av-line-live" x1="54" y1="160" x2="266" y2="165" />

        <!-- Nodes (4 up, 1 down) -->
        <circle class="av-node-up" cx="170" cy="55" r="15" />
        <text class="av-node-lbl" x="170" y="59" text-anchor="middle">✓</text>

        <circle class="av-node-up" cx="280" cy="55" r="15" />
        <text class="av-node-lbl" x="280" y="59" text-anchor="middle">✓</text>

        <!-- Down node in the middle -->
        <circle class="av-node-down" cx="220" cy="110" r="15" />
        <line class="av-x" x1="211" y1="101" x2="229" y2="119" />
        <line class="av-x" x1="229" y1="101" x2="211" y2="119" />

        <circle class="av-node-up" cx="170" cy="165" r="15" />
        <text class="av-node-lbl" x="170" y="169" text-anchor="middle">✓</text>

        <circle class="av-node-up" cx="280" cy="165" r="15" />
        <text class="av-node-lbl" x="280" y="169" text-anchor="middle">✓</text>
      </svg>
    </figure>
  </div>
</section>

<style>
  .landing-availability {
    margin-bottom: 40px;
  }

  .landing-availability-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .landing-availability__panel {
    margin: 0;
    padding: 16px;
    border-radius: var(--radius);
    background: var(--color-glass-bg);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    border: 1px solid var(--color-glass-border);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .landing-availability__panel--down {
    border-color: rgba(239, 68, 68, 0.25);
  }

  .landing-availability__panel--up {
    border-color: rgba(34, 197, 94, 0.25);
  }

  .landing-availability__caption {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .landing-availability__label {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .landing-availability__status {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .landing-availability__status--down {
    color: #ef4444;
  }

  .landing-availability__status--up {
    color: #22c55e;
  }

  .landing-availability__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  @media screen and (max-width: 640px) {
    .landing-availability-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
